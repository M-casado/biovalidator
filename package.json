{
  "name": "biovalidator",
  "version": "2.2.2",
  "description": "A nodejs JSON schema validator, extended from Ajv to include ontology validation.",
  "main": "src/biovalidator.js",
  "bin": {
    "biovalidator": "src/biovalidator.js"
  },
  "repository": "https://github.com/elixir-europe/biovalidator.git",
  "scripts": {
    "build:ui": "node scripts/build-ui.js",
    "start": "node src/biovalidator.js",
    "test": "jest",
    "test-watch": "nodemon --exec \"npm test\"",
    "travis-test": "jest test/validator.test.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "nodejs",
    "json",
    "schema",
    "validator"
  ],
  "author": "EMBL-EBI-AIT, fpenim, ke4, haseeb-gh, theisuru",
  "license": "Apache-2.0",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "2.1.1",
    "axios": "^1.18.1",
    "express": "^4.22.2",
    "glob": "^10.5.0",
    "node-cache": "^5.1.2",
    "npid": "^0.4.0",
    "winston": "^3.2.1",
    "winston-daily-rotate-file": "^3.10.0",
    "yargs": "^16.2.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "bootstrap": "^5.0.0",
    "bufferutil": "^4.0.2",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "rollup": "^3.30.0",
    "supertest": "^7.2.2",
    "terser": "^5.31.6",
    "ts-node": "^9.1.0",
    "typescript": "^4.1.2",
    "utf-8-validate": "^5.0.3"
  },
  "overrides": {
    "body-parser": "1.20.6"
  },
  "jest": {
    "moduleNameMapper": {
      "/axios/": "axios/dist/node/axios.cjs"
    },
    "testEnvironment": "node"
  }
}
